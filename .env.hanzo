# ==================================
# HANZO AI VENDOR MODE CONFIGURATION
# ==================================

# Copy base configuration
HOST=0.0.0.0
PORT=3080

# Database
MONGO_URI=mongodb://mongodb:27017/HanzoChat

# Domain
DOMAIN_CLIENT=http://localhost:3080
DOMAIN_SERVER=http://localhost:3080

# ==================================
# Brand Mode - Hanzo AI
# ==================================
BRAND_MODE=true
BRAND_NAME=Hanzo AI
BRAND_MODEL_DEFAULT=Hanzo Zen-1
BRAND_MODEL_PRO=Hanzo Zen-1 Pro

# Branding
APP_TITLE=Hanzo AI Chat
BRAND_COLOR=#000000
BRAND_LOGO_URL=/assets/hanzo-logo.svg

# Backend Configuration (using Anthropic)
BRAND_BACKEND_ENDPOINT=anthropic
BRAND_BACKEND_API_KEY=sk-ant-YOUR-KEY-HERE
BRAND_BACKEND_MODEL_DEFAULT=claude-3-5-sonnet-20241022
BRAND_BACKEND_MODEL_PRO=claude-3-opus-20240229

# ==================================
# Security (using defaults for demo)
# ==================================
JWT_SECRET=GENERATE-YOUR-OWN-SECRET-HERE
JWT_REFRESH_SECRET=GENERATE-YOUR-OWN-SECRET-HERE
CREDS_KEY=GENERATE-YOUR-OWN-KEY-HERE
CREDS_IV=GENERATE-YOUR-OWN-IV-HERE

# ==================================
# Other Settings
# ==================================
ALLOW_REGISTRATION=true
ALLOW_UNVERIFIED_EMAIL_LOGIN=true
DEBUG_LOGGING=true

# Search
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=GENERATE-YOUR-OWN-MEILI-KEY-HERE

# Disable other endpoints in brand mode
ENDPOINTS=